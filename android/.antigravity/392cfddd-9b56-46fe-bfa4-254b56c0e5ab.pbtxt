    replacement_chunks {
      target_content: "export const FeedReels: React.FC = () => {\n  const { items, filter, setFilter, searchQuery, setSearchQuery } = useApp();\n  const [isFormOpen, setIsFormOpen] = useState(false);\n  const [isStatsOpen, setIsStatsOpen] = useState(false);\n  const [isSearchActive, setIsSearchActive] = useState(false);\n  const containerRef = useRef<HTMLDivElement>(null);\n\n  // Filter items based on active category and text search query\n  const filteredItems = items.filter((item) => {\n    const matchesCategory = filter === \'all\' || item.category === filter;\n    const matchesSearch = searchQuery.trim() === \'\' || \n      item.title.toLowerCase().includes(searchQuery.toLowerCase()) || \n      (item.description && item.description.toLowerCase().includes(searchQuery.toLowerCase()));\n    return matchesCategory && matchesSearch;\n  });\n\n  // Scroll back to top smoothly when the filter or search changes\n  useEffect(() => {\n    if (containerRef.current) {\n      containerRef.current.scrollTop = 0;\n    }\n  }, [filter, searchQuery]);\n\n  return (\n    <div className=\"relative w-full h-full flex flex-col bg-[#F3F4F6] text-zinc-900 select-none overflow-hidden\">\n      \n      {/* 1. EDITORIAL HEADER OVERLAY: Styled EXACTLY like the \"DISCOVER\" header from the screenshot */}\n      <header className=\"absolute top-0 left-0 right-0 z-30 bg-gradient-to-b from-[#F3F4F6] via-[#F3F4F6]/85 to-transparent pt-8 pb-5 px-6 flex items-center justify-between pointer-events-none\">\n        \n        {isSearchActive ? (\n          <div className=\"w-full pointer-events-auto flex items-center gap-2 bg-white/95 border border-zinc-200 p-2 rounded-full shadow-lg\">\n            <Search className=\"w-4 h-4 text-zinc-400 ml-2\" />\n            <input \n              type=\"text\"\n              value={searchQuery}\n              onChange={(e) => setSearchQuery(e.target.value)}\n              placeholder=\"Buscar por t\303\255tulo o descripci\303\263n...\"\n              className=\"flex-grow bg-transparent text-xs font-sans text-zinc-900 placeholder-zinc-400 focus:outline-none\"\n              autoFocus\n            />\n            <button\n              onClick={() => {\n                setSearchQuery(\'\');\n                setIsSearchActive(false);\n              }}\n              className=\"w-7 h-7 rounded-full bg-zinc-100 hover:bg-zinc-200 text-zinc-500 hover:text-zinc-900 flex items-center justify-center transition-all\"\n            >\n              <X className=\"w-4 h-4\" />\n            </button>\n          </div>\n        ) : (\n          <>\n            {/* Left Side: Creative User Avatar circle - click to see Stats */}\n            <div className=\"pointer-events-auto\">\n              <div \n                onClick={() => setIsStatsOpen(true)}\n                className=\"relative w-11 h-11 rounded-full border border-white/80 shadow-md overflow-hidden bg-zinc-300 cursor-pointer hover:scale-105 active:scale-95 transition-all\"\n                title=\"Ver estad\303\255sticas\"\n              >\n                <img \n                  src=\"https://images.unsplash.com/photo-1534528741775-53994a69daeb?auto=format&fit=crop&w=150&q=80\" \n                  alt=\"Profile\" \n                  referrerPolicy=\"no-referrer\"\n                  className=\"w-full h-full object-cover\"\n                />\n                {/* Online status indicator */}\n                <span className=\"absolute bottom-0 right-0 w-2.5 h-2.5 rounded-full bg-yellow-400 border border-white animate-pulse\" />\n              </div>\n            </div>\n\n            {/* Center: Towering Display Typography \"DISCOVER\" or \"EXPLORAR\" */}\n            <div className=\"text-center flex flex-col items-center pointer-events-auto\">\n              <h1 className=\"font-display text-4xl font-extrabold tracking-[0.15em] text-zinc-950 uppercase select-none cursor-default leading-none\">\n                DISCOVER\n              </h1>\n              <span className=\"text-[9px] font-mono font-bold tracking-[0.25em] text-zinc-500 mt-1 uppercase\">\n                AQU\303\215 &amp; ALL\303\201 // FEED\n              </span>\n            </div>\n\n            {/* Right Side: Search and Add Buttons */}\n            <div className=\"pointer-events-auto flex items-center gap-1.5\">\n              <button\n                onClick={() => setIsSearchActive(true)}\n                className=\"w-11 h-11 rounded-full bg-white border border-zinc-200/80 text-zinc-950 flex items-center justify-center shadow-md hover:bg-zinc-50 hover:scale-105 active:scale-95 transition-all cursor-pointer\"\n                title=\"Buscar recursos\"\n              >\n                <Search className=\"w-5 h-5 text-zinc-900 stroke-[2]\" />\n              </button>\n\n              <button\n                onClick={() => setIsFormOpen(true)}\n                className=\"w-11 h-11 rounded-full bg-zinc-950 text-white flex items-center justify-center shadow-md hover:bg-zinc-800 hover:scale-105 active:scale-95 transition-all cursor-pointer\"\n                title=\"A\303\261adir nuevo recurso\"\n              >\n                <Plus className=\"w-5 h-5 stroke-[2.5]\" />\n              </button>\n            </div>\n          </>\n        )}\n      </header>\n\n      {/* 2. THE MAIN STREAMING FEED AREA */}\n      <div \n        ref={containerRef}\n        className=\"flex-grow w-full h-full snap-y snap-mandatory overflow-y-scroll scroll-smooth scrollbar-none pt-24 pb-28 bg-[#F3F4F6]\"\n        style={{ scrollbarWidth: \'none\', msOverflowStyle: \'none\' }}\n      >\n        {filteredItems.length > 0 ? (\n          filteredItems.map((item) => (\n            <CardContenido key={item.id} item={item} />\n          ))\n        ) : (\n          /* Custom centered empty state matching the clean, light aesthetic */\n          <div className=\"w-full h-full flex flex-col items-center justify-center p-8 text-center bg-[#F3F4F6] relative\">\n            <div className=\"absolute inset-0 bg-[radial-gradient(#e4e4e7_1px,transparent_1px)] [background-size:16px_16px] opacity-40 pointer-events-none\" />\n            \n            <div className=\"relative z-10 space-y-4 max-w-xs\">\n              <div className=\"w-20 h-20 rounded-full bg-white border border-zinc-200 shadow-md flex items-center justify-center mx-auto\">\n                <Compass className=\"w-9 h-9 text-zinc-400 animate-spin\" style={{ animationDuration: \'10s\' }} />\n              </div>\n              <h3 className=\"font-display text-xl font-bold tracking-widest text-zinc-950 uppercase\">\n                COLECCI\303\223N VAC\303\215A\n              </h3>\n              <p className=\"text-xs text-zinc-500 leading-relaxed font-normal\">\n                No hay elementos catalogados bajo la categor\303\255a de{\' \'}\n                <span className=\"text-zinc-900 font-bold uppercase font-mono bg-zinc-200 px-2 py-0.5 rounded\">\n                  {filter === \'all\' ? \'Ver todo\' : filter === \'aqui\' ? \'Aqu\303\255\' : \'All\303\241\'}\n                </span>\n                . \302\241S\303\251 el primero en documentar un hallazgo!\n              </p>\n              <button\n                onClick={() => setIsFormOpen(true)}\n                className=\"inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-zinc-950 text-white font-mono text-xs font-bold uppercase tracking-wider hover:bg-zinc-800 transition-all cursor-pointer shadow-lg\"\n              >\n                <Plus className=\"w-4 h-4\" />\n                <span>Agregar ahora</span>\n              </button>\n            </div>\n          </div>\n        )}\n      </div>\n\n      {/* 3. TRANS-GLASSMORPHIC FLOATING DOCK: Positioned and styled EXACTLY like the bottom dock in the screenshot */}\n      <div className=\"absolute bottom-6 left-6 right-6 z-30 pointer-events-none flex justify-center\">\n        <nav className=\"w-full max-w-[340px] h-16 rounded-[28px] backdrop-blur-xl bg-white/60 border border-white/50 shadow-[0_15px_35px_rgba(0,0,0,0.12)] flex items-center justify-around px-4 pointer-events-auto\">\n          \n          {/* Item 1: Compass icon (VER TODO) */}\n          <button\n            onClick={() => setFilter(\'all\')}\n            className={`flex flex-col items-center justify-center w-11 h-11 rounded-full transition-all duration-300 relative cursor-pointer ${\n              filter === \'all\' \n                ? \'bg-zinc-950 text-white shadow-md scale-105\' \n                : \'text-zinc-500 hover:text-zinc-900 hover:bg-zinc-100/50\'\n            }`}\n            title=\"Ver Todo\"\n          >\n            <Compass className=\"w-5 h-5 stroke-[2]\" />\n            <span className=\"text-[7px] font-mono font-bold tracking-widest absolute -bottom-3 uppercase\">\n              TODO\n            </span>\n          </button>\n\n          {/* Item 2: Heart icon (AQU\303\215 - COSAS BUENAS) */}\n          <button\n            onClick={() => setFilter(\'aqui\')}\n            className={`flex flex-col items-center justify-center w-11 h-11 rounded-full transition-all duration-300 relative cursor-pointer ${\n              filter === \'aqui\' \n                ? \'bg-yellow-400 text-black shadow-[0_0_15px_rgba(250,204,21,0.4)] scale-105\' \n                : \'text-zinc-500 hover:text-yellow-600 hover:bg-yellow-400/10\'\n            }`}\n            title=\"Filtrar Aqu\303\255 (Buenas)\"\n          >\n            <Heart className=\"w-5 h-5 stroke-[2] fill-current\" />\n            <span className=\"text-[7px] font-mono font-bold tracking-widest absolute -bottom-3 uppercase\">\n              AQU\303\215\n            </span>\n          </button>\n\n          {/* Item 3: Highlighted Central Adding Button */}\n          <button\n            onClick={() => setIsFormOpen(true)}\n            className=\"w-12 h-12 rounded-full bg-zinc-950 hover:bg-zinc-800 text-white flex items-center justify-center shadow-lg hover:scale-105 active:scale-95 transition-all cursor-pointer relative -translate-y-1 border border-white/20\"\n            title=\"Agregar Registro\"\n          >\n            <Plus className=\"w-6 h-6 stroke-[2.5]\" />\n          </button>\n\n          {/* Item 4: Alert icon (ALL\303\201 - COSAS MALAS) */}\n          <button\n            onClick={() => setFilter(\'alla\')}\n            className={`flex flex-col items-center justify-center w-11 h-11 rounded-full transition-all duration-300 relative cursor-pointer ${\n              filter === \'alla\' \n                ? \'bg-red-500 text-white shadow-[0_0_15px_rgba(239,68,68,0.4)] scale-105\' \n                : \'text-zinc-500 hover:text-red-600 hover:bg-red-500/10\'\n            }`}\n            title=\"Filtrar All\303\241 (Malas)\"\n          >\n            <AlertTriangle className=\"w-5 h-5 stroke-[2]\" />\n            <span className=\"text-[7px] font-mono font-bold tracking-widest absolute -bottom-3 uppercase\">\n              ALL\303\201\n            </span>\n          </button>\n\n          {/* Item 5: Small Stats Capsule Counter (Click to open metrics modal) */}\n          <button\n            onClick={() => setIsStatsOpen(true)}\n            className=\"flex items-center gap-1 bg-zinc-200/50 hover:bg-zinc-200/80 px-2 py-1 rounded-full border border-white/40 text-[9px] font-mono font-bold text-zinc-700 cursor-pointer transition-colors\"\n            title=\"Ver estad\303\255sticas y m\303\251tricas\"\n          >\n            <Layers className=\"w-3 h-3 text-zinc-500\" />\n            <span>{filteredItems.length}</span>\n          </button>\n\n        </nav>\n      </div>\n\n      {/* 4. FLOATING SCROLL-DOWN INDICATOR */}\n      {filteredItems.length > 1 && (\n        <div className=\"absolute top-28 right-6 z-20 pointer-events-none animate-bounce bg-white/80 p-2 rounded-full border border-zinc-200/80 shadow-md\">\n          <ArrowDown className=\"w-4 h-4 text-zinc-600\" />\n        </div>\n      )}\n\n      {/* Slide-Up Bottom Sheet Entry Form */}\n      <FormularioIngreso isOpen={isFormOpen} onClose={() => setIsFormOpen(false)} />\n      \n      {/* Analytics & Stats Breakdown Overlay Modal */}\n      <StatsModal isOpen={isStatsOpen} onClose={() => setIsStatsOpen(false)} />\n    </div>\n  );\n};"
      replacement_content: "export const FeedReels: React.FC = () => {\n  const { items, filter, setFilter, searchQuery, setSearchQuery, theme } = useApp();\n  const [isFormOpen, setIsFormOpen] = useState(false);\n  const [isStatsOpen, setIsStatsOpen] = useState(false);\n  const [isSearchActive, setIsSearchActive] = useState(false);\n  const containerRef = useRef<HTMLDivElement>(null);\n\n  // Filter items based on active category and text search query\n  const filteredItems = items.filter((item) => {\n    const matchesCategory = filter === \'all\' || item.category === filter;\n    const matchesSearch = searchQuery.trim() === \'\' || \n      item.title.toLowerCase().includes(searchQuery.toLowerCase()) || \n      (item.description && item.description.toLowerCase().includes(searchQuery.toLowerCase()));\n    return matchesCategory && matchesSearch;\n  });\n\n  // Scroll back to top smoothly when the filter or search changes\n  useEffect(() => {\n    if (containerRef.current) {\n      containerRef.current.scrollTop = 0;\n    }\n  }, [filter, searchQuery]);\n\n  return (\n    <div className={`relative w-full h-full flex flex-col select-none overflow-hidden transition-colors duration-500 ${\n      theme === \'dark\' ? \'bg-zinc-950 text-white\' : \'bg-[#F3F4F6] text-zinc-900\'\n    }`}>\n      \n      {/* 1. EDITORIAL HEADER OVERLAY: Styled EXACTLY like the \"DISCOVER\" header from the screenshot */}\n      <header className={`absolute top-0 left-0 right-0 z-30 pt-8 pb-5 px-6 flex items-center justify-between pointer-events-none transition-colors duration-500 bg-gradient-to-b ${\n        theme === \'dark\' \n          ? \'from-zinc-950 via-zinc-950/85 to-transparent\' \n          : \'from-[#F3F4F6] via-[#F3F4F6]/85 to-transparent\'\n      }`}>\n        \n        {isSearchActive ? (\n          <div className={`w-full pointer-events-auto flex items-center gap-2 border p-2 rounded-full shadow-lg transition-colors duration-300 ${\n            theme === \'dark\' \n              ? \'bg-zinc-900 border-zinc-800 text-white\' \n              : \'bg-white border-zinc-200 text-zinc-900\'\n          }`}>\n            <Search className=\"w-4 h-4 text-zinc-400 ml-2\" />\n            <input \n              type=\"text\"\n              value={searchQuery}\n              onChange={(e) => setSearchQuery(e.target.value)}\n              placeholder=\"Buscar por t\303\255tulo o descripci\303\263n...\"\n              className={`flex-grow bg-transparent text-xs font-sans placeholder-zinc-400 focus:outline-none ${\n                theme === \'dark\' ? \'text-white\' : \'text-zinc-900\'\n              }`}\n              autoFocus\n            />\n            <button\n              onClick={() => {\n                setSearchQuery(\'\');\n                setIsSearchActive(false);\n              }}\n              className={`w-7 h-7 rounded-full flex items-center justify-center transition-all ${\n                theme === \'dark\' ? \'bg-zinc-800 hover:bg-zinc-700 text-zinc-400\' : \'bg-zinc-100 hover:bg-zinc-200 text-zinc-500\'\n              }`}\n            >\n              <X className=\"w-4 h-4\" />\n            </button>\n          </div>\n        ) : (\n          <>\n            {/* Left Side: Creative User Avatar circle - click to see Stats */}\n            <div className=\"pointer-events-auto\">\n              <div \n                onClick={() => setIsStatsOpen(true)}\n                className=\"relative w-11 h-11 rounded-full border border-white/80 shadow-md overflow-hidden bg-zinc-300 cursor-pointer hover:scale-105 active:scale-95 transition-all\"\n                title=\"Ver estad\303\255sticas\"\n              >\n                <img \n                  src=\"https://images.unsplash.com/photo-1534528741775-53994a69daeb?auto=format&fit=crop&w=150&q=80\" \n                  alt=\"Profile\" \n                  referrerPolicy=\"no-referrer\"\n                  className=\"w-full h-full object-cover\"\n                />\n                {/* Online status indicator */}\n                <span className=\"absolute bottom-0 right-0 w-2.5 h-2.5 rounded-full bg-yellow-400 border border-white animate-pulse\" />\n              </div>\n            </div>\n\n            {/* Center: Towering Display Typography \"DISCOVER\" or \"EXPLORAR\" */}\n            <div className=\"text-center flex flex-col items-center pointer-events-auto\">\n              <h1 className={`font-display text-4xl font-extrabold tracking-[0.15em] uppercase select-none cursor-default leading-none ${\n                theme === \'dark\' ? \'text-white\' : \'text-zinc-950\'\n              }`}>\n                DISCOVER\n              </h1>\n              <span className={`text-[9px] font-mono font-bold tracking-[0.25em] mt-1 uppercase ${\n                theme === \'dark\' ? \'text-zinc-400\' : \'text-zinc-500\'\n              }`}>\n                AQU\303\215 &amp; ALL\303\201 // FEED\n              </span>\n            </div>\n\n            {/* Right Side: Search and Add Buttons */}\n            <div className=\"pointer-events-auto flex items-center gap-1.5\">\n              <button\n                onClick={() => setIsSearchActive(true)}\n                className={`w-11 h-11 rounded-full border flex items-center justify-center shadow-md hover:scale-105 active:scale-95 transition-all cursor-pointer ${\n                  theme === \'dark\' \n                    ? \'bg-zinc-900 border-zinc-800 text-zinc-100 hover:bg-zinc-800\' \n                    : \'bg-white border-zinc-200/80 text-zinc-950 hover:bg-zinc-50\'\n                }`}\n                title=\"Buscar recursos\"\n              >\n                <Search className=\"w-5 h-5 stroke-[2]\" />\n              </button>\n\n              <button\n                onClick={() => setIsFormOpen(true)}\n                className={`w-11 h-11 rounded-full flex items-center justify-center shadow-md hover:scale-105 active:scale-95 transition-all cursor-pointer ${\n                  theme === \'dark\'\n                    ? \'bg-white text-zinc-950 hover:bg-zinc-100\'\n                    : \'bg-zinc-950 text-white hover:bg-zinc-800\'\n                }`}\n                title=\"A\303\261adir nuevo recurso\"\n              >\n                <Plus className=\"w-5 h-5 stroke-[2.5]\" />\n              </button>\n            </div>\n          </>\n        )}\n      </header>\n\n      {/* 2. THE MAIN STREAMING FEED AREA */}\n      <div \n        ref={containerRef}\n        className={`flex-grow w-full h-full snap-y snap-mandatory overflow-y-scroll scroll-smooth scrollbar-none pt-24 pb-28 transition-colors duration-500 ${\n          theme === \'dark\' ? \'bg-zinc-950\' : \'bg-[#F3F4F6]\'\n        }`}\n        style={{ scrollbarWidth: \'none\', msOverflowStyle: \'none\' }}\n      >\n        {filteredItems.length > 0 ? (\n          filteredItems.map((item) => (\n            <CardContenido key={item.id} item={item} />\n          ))\n        ) : (\n          /* Custom centered empty state matching the clean, light aesthetic */\n          <div className=\"w-full h-full flex flex-col items-center justify-center p-8 text-center relative\">\n            <div className={`absolute inset-0 [background-size:16px_16px] opacity-40 pointer-events-none ${\n              theme === \'dark\' \n                ? \'bg-[radial-gradient(#27272a_1px,transparent_1px)]\' \n                : \'bg-[radial-gradient(#e4e4e7_1px,transparent_1px)]\'\n            }`} />\n            \n            <div className=\"relative z-10 space-y-4 max-w-xs\">\n              <div className={`w-20 h-20 rounded-full border shadow-md flex items-center justify-center mx-auto transition-colors ${\n                theme === \'dark\' ? \'bg-zinc-900 border-zinc-800\' : \'bg-white border-zinc-200\'\n              }`}>\n                <Compass className=\"w-9 h-9 text-zinc-400 animate-spin\" style={{ animationDuration: \'10s\' }} />\n              </div>\n              <h3 className={`font-display text-xl font-bold tracking-widest uppercase ${\n                theme === \'dark\' ? \'text-white\' : \'text-zinc-950\'\n              }`}>\n                COLECCI\303\223N VAC\303\215A\n              </h3>\n              <p className=\"text-xs text-zinc-500 leading-relaxed font-normal\">\n                No hay elementos catalogados bajo la categor\303\255a de{\' \'}\n                <span className={`font-bold uppercase font-mono px-2 py-0.5 rounded ${\n                  theme === \'dark\' ? \'text-white bg-zinc-800\' : \'text-zinc-900 bg-zinc-200\'\n                }`}>\n                  {filter === \'all\' ? \'Ver todo\' : filter === \'aqui\' ? \'Aqu\303\255\' : \'All\303\241\'}\n                </span>\n                . \302\241S\303\251 el primero en documentar un hallazgo!\n              </p>\n              <button\n                onClick={() => setIsFormOpen(true)}\n                className={`inline-flex items-center gap-2 px-5 py-2.5 rounded-full font-mono text-xs font-bold uppercase tracking-wider transition-all cursor-pointer shadow-lg ${\n                  theme === \'dark\' ? \'bg-white text-zinc-950 hover:bg-zinc-100\' : \'bg-zinc-950 text-white hover:bg-zinc-800\'\n                }`}\n              >\n                <Plus className=\"w-4 h-4\" />\n                <span>Agregar ahora</span>\n              </button>\n            </div>\n          </div>\n        )}\n      </div>\n\n      {/* 3. TRANS-GLASSMORPHIC FLOATING DOCK: Positioned and styled EXACTLY like the bottom dock in the screenshot */}\n      <div className=\"absolute bottom-6 left-6 right-6 z-30 pointer-events-none flex justify-center\">\n        <nav className={`w-full max-w-[340px] h-16 rounded-[28px] backdrop-blur-xl border flex items-center justify-around px-4 pointer-events-auto transition-colors duration-500 ${\n          theme === \'dark\' \n            ? \'bg-zinc-900/80 border-zinc-800 shadow-[0_15px_35px_rgba(0,0,0,0.5)] text-white\' \n            : \'bg-white/60 border-white/50 shadow-[0_15px_35px_rgba(0,0,0,0.12)] text-zinc-900\'\n        }`}>\n          \n          {/* Item 1: Compass icon (VER TODO) */}\n          <button\n            onClick={() => setFilter(\'all\')}\n            className={`flex flex-col items-center justify-center w-11 h-11 rounded-full transition-all duration-300 relative cursor-pointer ${\n              filter === \'all\' \n                ? (theme === \'dark\' ? \'bg-white text-zinc-950 shadow-md scale-105\' : \'bg-zinc-950 text-white shadow-md scale-105\')\n                : (theme === \'dark\' ? \'text-zinc-400 hover:text-white hover:bg-zinc-800/50\' : \'text-zinc-500 hover:text-zinc-900 hover:bg-zinc-100/50\')\n            }`}\n            title=\"Ver Todo\"\n          >\n            <Compass className=\"w-5 h-5 stroke-[2]\" />\n            <span className=\"text-[7px] font-mono font-bold tracking-widest absolute -bottom-3 uppercase\">\n              TODO\n            </span>\n          </button>\n\n          {/* Item 2: Heart icon (AQU\303\215 - COSAS BUENAS) */}\n          <button\n            onClick={() => setFilter(\'aqui\')}\n            className={`flex flex-col items-center justify-center w-11 h-11 rounded-full transition-all duration-300 relative cursor-pointer ${\n              filter === \'aqui\' \n                ? \'bg-yellow-400 text-black shadow-[0_0_15px_rgba(250,204,21,0.4)] scale-105\' \n                : (theme === \'dark\' ? \'text-zinc-400 hover:text-yellow-400 hover:bg-yellow-400/10\' : \'text-zinc-500 hover:text-yellow-600 hover:bg-yellow-400/10\')\n            }`}\n            title=\"Filtrar Aqu\303\255 (Buenas)\"\n          >\n            <Heart className=\"w-5 h-5 stroke-[2] fill-current\" />\n            <span className=\"text-[7px] font-mono font-bold tracking-widest absolute -bottom-3 uppercase\">\n              AQU\303\215\n            </span>\n          </button>\n\n          {/* Item 3: Highlighted Central Adding Button */}\n          <button\n            onClick={() => setIsFormOpen(true)}\n            className={`w-12 h-12 rounded-full flex items-center justify-center shadow-lg hover:scale-105 active:scale-95 transition-all cursor-pointer relative -translate-y-1 border ${\n              theme === \'dark\' \n                ? \'bg-white text-zinc-950 hover:bg-zinc-100 border-white/20\' \n                : \'bg-zinc-950 text-white hover:bg-zinc-800 border-white/20\'\n            }`}\n            title=\"Agregar Registro\"\n          >\n            <Plus className=\"w-6 h-6 stroke-[2.5]\" />\n          </button>\n\n          {/* Item 4: Alert icon (ALL\303\201 - COSAS MALAS) */}\n          <button\n            onClick={() => setFilter(\'alla\')}\n            className={`flex flex-col items-center justify-center w-11 h-11 rounded-full transition-all duration-300 relative cursor-pointer ${\n              filter === \'alla\' \n                ? \'bg-red-500 text-white shadow-[0_0_15px_rgba(239,68,68,0.4)] scale-105\' \n                : (theme === \'dark\' ? \'text-zinc-400 hover:text-red-400 hover:bg-red-500/10\' : \'text-zinc-500 hover:text-red-600 hover:bg-red-500/10\')\n            }`}\n            title=\"Filtrar All\303\241 (Malas)\"\n          >\n            <AlertTriangle className=\"w-5 h-5 stroke-[2]\" />\n            <span className=\"text-[7px] font-mono font-bold tracking-widest absolute -bottom-3 uppercase\">\n              ALL\303\201\n            </span>\n          </button>\n\n          {/* Item 5: Small Stats Capsule Counter (Click to open metrics modal) */}\n          <button\n            onClick={() => setIsStatsOpen(true)}\n            className={`flex items-center gap-1 px-2 py-1 rounded-full border text-[9px] font-mono font-bold cursor-pointer transition-all ${\n              theme === \'dark\' \n                ? \'bg-zinc-800 hover:bg-zinc-700 border-zinc-700 text-zinc-300\' \n                : \'bg-zinc-200/50 hover:bg-zinc-200/80 border-white/40 text-zinc-700\'\n            }`}\n            title=\"Ver estad\303\255sticas y m\303\251tricas\"\n          >\n            <Layers className=\"w-3 h-3 text-zinc-500\" />\n            <span>{filteredItems.length}</span>\n          </button>\n\n        </nav>\n      </div>\n\n      {/* 4. FLOATING SCROLL-DOWN INDICATOR */}\n      {filteredItems.length > 1 && (\n        <div className={`absolute top-28 right-6 z-20 pointer-events-none animate-bounce p-2 rounded-full border shadow-md transition-colors ${\n          theme === \'dark\' \n            ? \'bg-zinc-900 border-zinc-800 text-zinc-300\' \n            : \'bg-white/80 border-zinc-200/80 text-zinc-600\'\n        }`}>\n          <ArrowDown className=\"w-4 h-4\" />\n        </div>\n      )}\n\n      {/* Slide-Up Bottom Sheet Entry Form */}\n      <FormularioIngreso isOpen={isFormOpen} onClose={() => setIsFormOpen(false)} />\n      \n      {/* Analytics & Stats Breakdown Overlay Modal */}\n      <StatsModal isOpen={isStatsOpen} onClose={() => setIsStatsOpen(false)} />\n    </div>\n  );\n};"
