      target_content: "  const [filter, setFilter] = useState<\'all\' | CategoryType>(\'all\');\n  const [layoutMode, setLayoutMode] = useState<\'mobile\' | \'desktop\'>(\'mobile\');\n  const [searchQuery, setSearchQuery] = useState(\'\');\n\n  useEffect(() => {\n    localStorage.setItem(\'curador_items\', JSON.stringify(items));\n  }, [items]);\n\n  useEffect(() => {\n    localStorage.setItem(\'curador_likes\', JSON.stringify(likes));\n  }, [likes]);\n\n  const addItem = (newItem: Omit<CurationItem, \'id\' | \'createdAt\'>) => {\n    const createdItem: CurationItem = {\n      ...newItem,\n      id: crypto.randomUUID ? crypto.randomUUID() : Math.random().toString(36).substr(2, 9),\n      createdAt: new Date().toISOString(),\n    };\n    setItems((prev) => [createdItem, ...prev]);\n  };\n\n  const deleteItem = (id: string) => {\n    setItems((prev) => prev.filter((item) => item.id !== id));\n    setLikes((prev) => prev.filter((likedId) => likedId !== id));\n  };\n\n  const toggleLike = (id: string) => {\n    setLikes((prev) => \n      prev.includes(id) ? prev.filter((likedId) => likedId !== id) : [...prev, id]\n    );\n  };\n\n  const resetDatabase = () => {\n    setItems(INITIAL_ITEMS);\n    setLikes([\'1\', \'3\', \'5\']);\n    setFilter(\'all\');\n    setSearchQuery(\'\');\n  };\n\n  return (\n    <AppContext.Provider\n      value={{\n        items,\n        addItem,\n        deleteItem,\n        filter,\n        setFilter,\n        layoutMode,\n        setLayoutMode,\n        likes,\n        toggleLike,\n        searchQuery,\n        setSearchQuery,\n        resetDatabase,\n      }}\n    >"
      replacement_content: "  const [filter, setFilter] = useState<\'all\' | CategoryType>(\'all\');\n  const [layoutMode, setLayoutMode] = useState<\'mobile\' | \'desktop\'>(\'mobile\');\n  const [searchQuery, setSearchQuery] = useState(\'\');\n  const [theme, setTheme] = useState<\'light\' | \'dark\'>(() => {\n    const saved = localStorage.getItem(\'curador_theme\');\n    if (saved === \'dark\' || saved === \'light\') {\n      return saved;\n    }\n    // Default to light\n    return \'light\';\n  });\n\n  useEffect(() => {\n    localStorage.setItem(\'curador_items\', JSON.stringify(items));\n  }, [items]);\n\n  useEffect(() => {\n    localStorage.setItem(\'curador_likes\', JSON.stringify(likes));\n  }, [likes]);\n\n  useEffect(() => {\n    localStorage.setItem(\'curador_theme\', theme);\n    // Sync class list with document html/body for utility tailwind classes\n    if (theme === \'dark\') {\n      document.documentElement.classList.add(\'dark\');\n    } else {\n      document.documentElement.classList.remove(\'dark\');\n    }\n  }, [theme]);\n\n  const addItem = (newItem: Omit<CurationItem, \'id\' | \'createdAt\'>) => {\n    const createdItem: CurationItem = {\n      ...newItem,\n      id: crypto.randomUUID ? crypto.randomUUID() : Math.random().toString(36).substr(2, 9),\n      createdAt: new Date().toISOString(),\n    };\n    setItems((prev) => [createdItem, ...prev]);\n  };\n\n  const deleteItem = (id: string) => {\n    setItems((prev) => prev.filter((item) => item.id !== id));\n    setLikes((prev) => prev.filter((likedId) => likedId !== id));\n  };\n\n  const toggleLike = (id: string) => {\n    setLikes((prev) => \n      prev.includes(id) ? prev.filter((likedId) => likedId !== id) : [...prev, id]\n    );\n  };\n\n  const toggleTheme = () => {\n    setTheme((prev) => (prev === \'light\' ? \'dark\' : \'light\'));\n  };\n\n  const resetDatabase = () => {\n    setItems(INITIAL_ITEMS);\n    setLikes([\'1\', \'3\', \'5\']);\n    setFilter(\'all\');\n    setSearchQuery(\'\');\n  };\n\n  return (\n    <AppContext.Provider\n      value={{\n        items,\n        addItem,\n        deleteItem,\n        filter,\n        setFilter,\n        layoutMode,\n        setLayoutMode,\n        likes,\n        toggleLike,\n        searchQuery,\n        setSearchQuery,\n        resetDatabase,\n        theme,\n        toggleTheme,\n      }}\n    >"
    }
