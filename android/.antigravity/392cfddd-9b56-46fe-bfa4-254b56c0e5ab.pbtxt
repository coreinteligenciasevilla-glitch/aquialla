  file_change {
    absolute_path_uri: "file:///src/components/CardContenido.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React from \'react\';\nimport { CurationItem } from \'../types\';\nimport { useApp } from \'../context/AppContext\';\nimport { \n  Youtube, \n  Instagram, \n  Linkedin, \n  Globe, \n  Zap, \n  ExternalLink, \n  Trash2, \n  Sparkles,\n  AlertTriangle,\n  Heart\n} from \'lucide-react\';\n\ninterface CardContenidoProps {\n  item: CurationItem;\n}\n\nexport const CardContenido: React.FC<CardContenidoProps> = ({ item }) => {\n  const { deleteItem } = useApp();\n  const isAqui = item.category === \'aqui\';\n\n  // Helper to select icon based on platform\n  const getPlatformIcon = (type: string) => {\n    switch (type) {\n      case \'youtube\':\n        return <Youtube className=\"w-4 h-4 text-white\" />;\n      case \'instagram\':\n        return <Instagram className=\"w-4 h-4 text-white\" />;\n      case \'linkedin\':\n        return <Linkedin className=\"w-4 h-4 text-white\" />;\n      case \'tiktok\':\n        return <Zap className=\"w-4 h-4 text-white animate-pulse\" />;\n      default:\n        return <Globe className=\"w-4 h-4 text-white\" />;\n    }\n  };\n\n  // Helper to get stylized platform label\n  const getPlatformLabel = (type: string) => {\n    switch (type) {\n      case \'youtube\': return \'YouTube\';\n      case \'instagram\': return \'Instagram\';\n      case \'linkedin\': return \'LinkedIn\';\n      case \'tiktok\': return \'TikTok\';\n      default: return \'Web\';\n    }\n  };\n\n  // Generate a gorgeous custom gradient/mesh background based on the content platform and category\n  // This mimics the full-bleed high-quality travel images of Mount Fuji / Eiffel Tower from the user\'s reference image\n  const getCardBackground = () => {\n    if (isAqui) {\n      switch (item.contentType) {\n        case \'youtube\':\n          return \'bg-gradient-to-tr from-amber-500 via-rose-500 to-indigo-950\';\n        case \'instagram\':\n          return \'bg-gradient-to-tr from-purple-600 via-pink-500 to-orange-400\';\n        case \'tiktok\':\n          return \'bg-gradient-to-tr from-teal-500 via-emerald-600 to-zinc-950\';\n        case \'linkedin\':\n          return \'bg-gradient-to-tr from-blue-700 via-indigo-600 to-slate-950\';\n        default:\n          return \'bg-gradient-to-tr from-yellow-400 via-amber-600 to-indigo-900\';\n      }\n    } else {\n      // \"All\303\241\" (Crimson, Dark warnings)\n      switch (item.contentType) {\n        case \'youtube\':\n          return \'bg-gradient-to-tr from-red-600 via-rose-900 to-zinc-950\';\n        case \'instagram\':\n          return \'bg-gradient-to-tr from-red-700 via-purple-900 to-neutral-950\';\n        case \'tiktok\':\n          return \'bg-gradient-to-tr from-red-500 via-orange-600 to-zinc-950\';\n        case \'linkedin\':\n          return \'bg-gradient-to-tr from-rose-800 via-zinc-900 to-black\';\n        default:\n          return \'bg-gradient-to-tr from-red-600 via-stone-800 to-zinc-950\';\n      }\n    }\n  };\n\n  return (\n    <div \n      id={`card-${item.id}`}\n      className=\"snap-start w-full h-full flex-shrink-0 flex flex-col justify-between p-5 relative overflow-hidden bg-zinc-100\"\n    >\n      {/* Editorial Card frame similar to the Toky/Paris cards with extremely rounded 32px corners */}\n      <div \n        className={`w-full h-full rounded-[36px] overflow-hidden shadow-[0_15px_35px_rgba(0,0,0,0.18)] relative flex flex-col justify-between p-6 transition-all duration-500 ${getCardBackground()}`}\n      >\n        {/* Abstract cyber grid graphic overlay for extra texture depth */}\n        <div className=\"absolute inset-0 bg-[radial-gradient(#ffffff_1px,transparent_1px)] [background-size:16px_16px] opacity-10 pointer-events-none\" />\n        \n        {/* Soft bottom vignette overlay to protect text legibility */}\n        <div className=\"absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-black/10 pointer-events-none\" />\n\n        {/* TOP OF THE CARD: Category Tag & Quick Actions */}\n        <div className=\"relative z-10 flex justify-between items-center w-full\">\n          {/* Custom category pill designed EXACTLY like the \"Last minute tours\" coral pill from the screenshot */}\n          <div \n            className={`px-3 py-1.5 rounded-full backdrop-blur-md border text-[10px] font-sans font-bold tracking-wider uppercase flex items-center gap-1.5 ${\n              isAqui \n                ? \'bg-yellow-400/20 border-yellow-400/30 text-yellow-300\' \n                : \'bg-red-500/20 border-red-500/30 text-red-300\'\n            }`}\n          >\n            {isAqui ? (\n              <Sparkles className=\"w-3 h-3 text-yellow-400\" />\n            ) : (\n              <AlertTriangle className=\"w-3 h-3 text-red-400\" />\n            )}\n            <span>{isAqui ? \'Aqu\303\255 // Inspiraci\303\263n\' : \'All\303\241 // Evitar\'}</span>\n          </div>\n\n          {/* Top-Right action: circular like/bookmark style button (acts as the DELETE action) */}\n          <button\n            onClick={() => deleteItem(item.id)}\n            className=\"w-10 h-10 rounded-full bg-white/15 hover:bg-red-500 hover:scale-105 active:scale-95 text-white border border-white/20 flex items-center justify-center transition-all duration-300 backdrop-blur-md cursor-pointer\"\n            title=\"Eliminar de mi colecci\303\263n\"\n          >\n            <Trash2 className=\"w-4 h-4\" />\n          </button>\n        </div>\n\n        {/* MIDDLE-BOTTOM OF THE CARD: Context and Metadata Layout */}\n        <div className=\"relative z-10 mt-auto pt-6 space-y-4\">\n          \n          {/* Card Meta Row: Platform badge on left, dynamic tag on right mimicking the pricing metadata */}\n          <div className=\"flex items-center justify-between\">\n            <div className=\"flex items-center gap-1.5 bg-white/10 px-2.5 py-1 rounded-full border border-white/10 backdrop-blur-md\">\n              {getPlatformIcon(item.contentType)}\n              <span className=\"text-[10px] font-mono tracking-widest text-white/90 uppercase\">\n                {getPlatformLabel(item.contentType)}\n              </span>\n            </div>\n\n            {/* Price tag mirror styled like \"from $1500 / per 10 days\" */}\n            <div className=\"text-right\">\n              <span className=\"block text-xs font-mono font-bold uppercase tracking-wider text-white/90\">\n                INFO // LINK\n              </span>\n              <span className=\"block text-[8px] font-mono text-white/60 tracking-widest uppercase\">\n                ORIGINAL SOURCE\n              </span>\n            </div>\n          </div>\n\n          {/* Title & Description stack with top-notch legibility */}\n          <div className=\"space-y-1.5\">\n            <h3 className=\"text-xl md:text-2xl font-bold text-white tracking-tight leading-tight line-clamp-3\">\n              {item.title}\n            </h3>\n            \n            {item.description && (\n              <p className=\"text-xs text-white/70 leading-relaxed font-light line-clamp-3 max-w-sm\">\n                {item.description}\n              </p>\n            )}\n          </div>\n\n          {/* BOTTOM PILL BUTTON: Designed EXACTLY like the transparent black pill \"Let\'s start\" button */}\n          <div className=\"pt-2\">\n            <a\n              href={item.url}\n              target=\"_blank\"\n              rel=\"noopener noreferrer\"\n              className=\"w-full py-3 px-4 rounded-full border border-white/30 hover:bg-white hover:text-black hover:border-white text-white text-xs font-mono font-bold tracking-widest uppercase flex items-center justify-center gap-2 transition-all duration-300 backdrop-blur-md cursor-pointer\"\n            >\n              <span>Ver contenido original</span>\n              <ExternalLink className=\"w-3.5 h-3.5\" />\n            </a>\n          </div>\n\n        </div>\n      </div>\n    </div>\n  );\n};\n"
    }
