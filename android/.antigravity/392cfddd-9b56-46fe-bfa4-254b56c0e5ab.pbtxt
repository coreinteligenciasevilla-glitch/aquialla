      original_chunk {
        target_content: "  // Generate a gorgeous custom gradient/mesh background based on the content platform and category\n  // This mimics the full-bleed high-quality travel images of Mount Fuji / Eiffel Tower from the user\'s reference image\n  const getCardBackground = () => {\n    if (isAqui) {\n      switch (item.contentType) {\n        case \'youtube\':\n          return \'bg-gradient-to-tr from-amber-500 via-rose-500 to-indigo-950\';\n        case \'instagram\':\n          return \'bg-gradient-to-tr from-purple-600 via-pink-500 to-orange-400\';\n        case \'tiktok\':\n          return \'bg-gradient-to-tr from-teal-500 via-emerald-600 to-zinc-950\';\n        case \'linkedin\':\n          return \'bg-gradient-to-tr from-blue-700 via-indigo-600 to-slate-950\';\n        default:\n          return \'bg-gradient-to-tr from-yellow-400 via-amber-600 to-indigo-900\';\n      }\n    } else {\n      // \"All\303\241\" (Crimson, Dark warnings)\n      switch (item.contentType) {\n        case \'youtube\':\n          return \'bg-gradient-to-tr from-red-600 via-rose-900 to-zinc-950\';\n        case \'instagram\':\n          return \'bg-gradient-to-tr from-red-700 via-purple-900 to-neutral-950\';\n        case \'tiktok\':\n          return \'bg-gradient-to-tr from-red-500 via-orange-600 to-zinc-950\';\n        case \'linkedin\':\n          return \'bg-gradient-to-tr from-rose-800 via-zinc-900 to-black\';\n        default:\n          return \'bg-gradient-to-tr from-red-600 via-stone-800 to-zinc-950\';\n      }\n    }\n  };"
        replacement_content: "  // Generate consistent color gradients depending strictly on the category: \'aqui\' (Yellow) or \'alla\' (Red)\n  const getCardBackground = () => {\n    if (isAqui) {\n      // Premium Neon Yellow to Dark Amber gradient\n      return \'bg-gradient-to-tr from-amber-500 via-yellow-500 to-zinc-900\';\n    } else {\n      // Premium Neon Red to Dark Crimson gradient\n      return \'bg-gradient-to-tr from-red-600 via-rose-700 to-zinc-950\';\n    }\n  };"
      }
      num_matches: 1
    }
  }
