\',\n    url: \'https://example.com/bad-performance-case\',\n    description: \'Caso de estudio de c\303\263mo importar lodash completo en lugar de sub-m\303\263dulos espec\303\255ficos infl\303\263 el bundle de producci\303\263n en 2.3MB innecesarios.\',\n    category: \'alla\',\n    contentType: \'web\',\n    createdAt: new Date(Date.now() - 3600000 * 6).toISOString(), // 6h ago\n  },\n  {\n    id: \'5\',\n    title: \'Micro-interacciones Fluidas con Framer Motion\',\n    url: \'https://tiktok.com/@creative.dev/video/89127391\',\n    description: \'Aprende a animar listas din\303\241micas con layouts compartidos de forma fluida y con s\303\263lo un par de l\303\255neas de c\303\263digo declarativo.\',\n    category: \'aqui\',\n    contentType: \'tiktok\',\n    createdAt: new Date(Date.now() - 3600000 * 2).toISOString(), // 2h ago\n  },\n  {\n    id: \'6\',\n    title: \'Botones de Acci\303\263n Sin Target T\303\241ctil M\303\255nimo\',\n    url: \'https://tiktok.com/@ux.fails/video/77218391\',\n    description: \'Ejemplo de por qu\303\251 dise\303\261ar botones menores a 44px de tama\303\261o t\303\241ctil rompe la usabilidad m\303\263vil y frustra a los usuarios finales.\',\n    category: \'alla\',\n    contentType: \'tiktok\',\n    createdAt: new Date(Date.now() - 3600000 * 1).toISOString(), // 1h ago\n  }\n];\n\nexport const AppProvider: React.FC<{ children: React.ReactNode }> = ({ children }) => {\n  const [items, setItems] = useState<CurationItem[]>(() => {\n    const saved = localStorage.getItem(\'curador_items\');\n    if (saved) {\n      try {\n        return JSON.parse(saved);\n      } catch (e) {\n        console.error(\'Error al parsear items desde localStorage\', e);\n      }\n    }\n    return INITIAL_ITEMS;\n  });\n\n  const [filter, setFilter] = useState<\'all\' | CategoryType>(\'all\');\n  const [layoutMode, setLayoutMode] = useState<\'mobile\' | \'desktop\'>(\'mobile\');\n\n  useEffect(() => {\n    localStorage.setItem(\'curador_items\', JSON.stringify(items));\n  }, [items]);\n\n  const addItem = (newItem: Omit<CurationItem, \'id\' | \'createdAt\'>) => {\n    const createdItem: CurationItem = {\n      ...newItem,\n      id: crypto.randomUUID ? crypto.randomUUID() : Math.random().toString(36).substr(2, 9),\n      createdAt: new Date().toISOString(),\n    };\n    setItems((prev) => [createdItem, ...prev]);\n  };\n\n  const deleteItem = (id: string) => {\n    setItems((prev) => prev.filter((item) => item.id !== id));\n  };\n\n  return (\n    <AppContext.Provider\n      value={{\n        items,\n        addItem,\n        deleteItem,\n        filter,\n        setFilter,\n        layoutMode,\n        setLayoutMode,\n      }}\n    >\n      {children}\n    </AppContext.Provider>\n  );\n};"
      replacement_content: "interface AppContextProps {\n  items: CurationItem[];\n  addItem: (item: Omit<CurationItem, \'id\' | \'createdAt\'>) => void;\n  deleteItem: (id: string) => void;\n  filter: \'all\' | CategoryType;\n  setFilter: (filter: \'all\' | CategoryType) => void;\n  layoutMode: \'mobile\' | \'desktop\';\n  setLayoutMode: (mode: \'mobile\' | \'desktop\') => void;\n  likes: string[];\n  toggleLike: (id: string) => void;\n  searchQuery: string;\n  setSearchQuery: (query: string) => void;\n  resetDatabase: () => void;\n}\n\nconst AppContext = createContext<AppContextProps | undefined>(undefined);\n\nconst INITIAL_ITEMS: CurationItem[] = [\n  {\n    id: \'1\',\n    title: \'React 19 Clean Forms con useActionState\',\n    url: \'https://www.youtube.com/watch?v=y_Y6u49vYTo\',\n    description: \'Incre\303\255ble patr\303\263n para simplificar la gesti\303\263n de estados de carga, errores y \303\251xito en formularios interactivos sin boilerplate adicional.\',\n    category: \'aqui\',\n    contentType: \'youtube\',\n    createdAt: new Date(Date.now() - 3600000 * 24).toISOString(), // 1 day ago\n  },\n  {\n    id: \'2\',\n    title: \'El Peligroso Antipantr\303\263n del useEffect Infinito\',\n    url: \'https://www.linkedin.com/posts/react-hooks-pitfalls\',\n    description: \'Un desglose t\303\251cnico de c\303\263mo mutar estados dentro de un useEffect sin dependencias primitivas estables causa loops de re-render destructivos.\',\n    category: \'alla\',\n    contentType: \'linkedin\',\n    createdAt: new Date(Date.now() - 3600000 * 18).toISOString(), // 18h ago\n  },\n  {\n    id: \'3\',\n    title: \'Visuales Neon Glassmorphism Modernos\',\n    url: \'https://www.instagram.com/p/C-design-trends\',\n    description: \'Gu\303\255a paso a paso para lograr el desenfoque de fondo perfecto (backdrop-blur) combinado con bordes transl\303\272cidos de alto impacto t\303\241ctil.\',\n    category: \'aqui\',\n    contentType: \'instagram\',\n    createdAt: new Date(Date.now() - 3600000 * 12).toISOString(), // 12h ago\n  },\n  {\n    id: \'4\',\n    title: \'Librer\303\255as Gigantes Sin Tree-shaking en Producci\303\263n\',\n    url: \'https://example.com/bad-performance-case\',\n    description: \'Caso de estudio de c\303\263mo importar lodash completo en lugar de sub-m\303\263dulos espec\303\255ficos infl\303\263 el bundle de producci\303\263n en 2.3MB innecesarios.\',\n    category: \'alla\',\n    contentType: \'web\',\n    createdAt: new Date(Date.now() - 3600000 * 6).toISOString(), // 6h ago\n  },\n  {\n    id: \'5\',\n    title: \'Micro-interacciones Fluidas con Framer Motion\',\n    url: \'https://tiktok.com/@creative.dev/video/89127391\',\n    description: \'Aprende a animar listas din\303\241micas con layouts compartidos de forma fluida y con s\303\263lo un par de l\303\255neas de c\303\263digo declarativo.\',\n    category: \'aqui\',\n    contentType: \'tiktok\',\n    createdAt: new Date(Date.now() - 3600000 * 2).toISOString(), // 2h ago\n  },\n  {\n    id: \'6\',\n    title: \'Botones de Acci\303\263n Sin Target T\303\241ctil M\303\255nimo\',\n    url: \'https://tiktok.com/@ux.fails/video/77218391\',\n    description: \'Ejemplo de por qu\303\251 dise\303\261ar botones menores a 44px de tama\303\261o t\303\241ctil rompe la usabilidad m\303\263vil y frustra a los usuarios finales.\',\n    category: \'alla\',\n    contentType: \'tiktok\',\n    createdAt: new Date(Date.now() - 3600000 * 1).toISOString(), // 1h ago\n  }\n];\n\nexport const AppProvider: React.FC<{ children: React.ReactNode }> = ({ children }) => {\n  const [items, setItems] = useState<CurationItem[]>(() => {\n    const saved = localStorage.getItem(\'curador_items\');\n    if (saved) {\n      try {\n        return JSON.parse(saved);\n      } catch (e) {\n        console.error(\'Error al parsear items desde localStorage\', e);\n      }\n    }\n    return INITIAL_ITEMS;\n  });\n\n  const [likes, setLikes] = useState<string[]>(() => {\n    const saved = localStorage.getItem(\'curador_likes\');\n    if (saved) {\n      try {\n        return JSON.parse(saved);\n      } catch {\n        return [];\n      }\n    }\n    return [\'1\', \'3\', \'5\']; // Default likes\n  });\n\n  const [filter, setFilter] = useState<\'all\' | CategoryType>(\'all\');\n  const [layoutMode, setLayoutMode] = useState<\'mobile\' | \'desktop\'>(\'mobile\');\n  const [searchQuery, setSearchQuery] = useState(\'\');\n\n  useEffect(() => {\n    localStorage.setItem(\'curador_items\', JSON.stringify(items));\n  }, [items]);\n\n  useEffect(() => {\n    localStorage.setItem(\'curador_likes\', JSON.stringify(likes));\n  }, [likes]);\n\n  const addItem = (newItem: Omit<CurationItem, \'id\' | \'createdAt\'>) => {\n    const createdItem: CurationItem = {\n      ...newItem,\n      id: crypto.randomUUID ? crypto.randomUUID() : Math.random().toString(36).substr(2, 9),\n      createdAt: new Date().toISOString(),\n    };\n    setItems((prev) => [createdItem, ...prev]);\n  };\n\n  const deleteItem = (id: string) => {\n    setItems((prev) => prev.filter((item) => item.id !== id));\n    setLikes((prev) => prev.filter((likedId) => likedId !== id));\n  };\n\n  const toggleLike = (id: string) => {\n    setLikes((prev) => \n      prev.includes(id) ? prev.filter((likedId) => likedId !== id) : [...prev, id]\n    );\n  };\n\n  const resetDatabase = () => {\n    setItems(INITIAL_ITEMS);\n    setLikes([\'1\', \'3\', \'5\']);\n    setFilter(\'all\');\n    setSearchQuery(\'\');\n  };\n\n  return (\n    <AppContext.Provider\n      value={{\n        items,\n        addItem,\n        deleteItem,\n        filter,\n        setFilter,\n        layoutMode,\n        setLayoutMode,\n        likes,\n        toggleLike,\n        searchQuery,\n        setSearchQuery,\n        resetDatabase,\n      }}\n    >\n      {children}\n    </AppContext.Provider>\n  );\n};"
