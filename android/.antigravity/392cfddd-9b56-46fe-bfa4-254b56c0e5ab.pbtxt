    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useRef, useEffect, useState } from \'react\';\nimport { useApp } from \'../context/AppContext\';\nimport { CardContenido } from \'./CardContenido\';\nimport { FormularioIngreso } from \'./FormularioIngreso\';\nimport { \n  Sparkles, \n  AlertTriangle, \n  FolderHeart, \n  Plus, \n  Layers,\n  ArrowUpDown\n} from \'lucide-react\';\n\nexport const FeedReels: React.FC = () => {\n  const { items, filter, setFilter } = useApp();\n  const [isFormOpen, setIsFormOpen] = useState(false);\n  const containerRef = useRef<HTMLDivElement>(null);\n\n  // Filter items based on active category\n  const filteredItems = items.filter(\n    (item) => filter === \'all\' || item.category === filter\n  );\n\n  // Scroll back to top smoothly when the filter changes\n  useEffect(() => {\n    if (containerRef.current) {\n      containerRef.current.scrollTop = 0;\n    }\n  }, [filter]);\n\n  return (\n    <div className=\"relative w-full h-full flex flex-col bg-zinc-950 text-white select-none\">\n      \n      {/* Absolute Header Overlay with Brand & Fast Filters */}\n      <div className=\"absolute top-0 left-0 right-0 z-30 bg-gradient-to-b from-zinc-950/90 via-zinc-950/50 to-transparent pt-4 pb-6 px-4 backdrop-blur-[2px] pointer-events-none\">\n        \n        {/* Top Branding Section */}\n        <div className=\"flex justify-between items-center mb-4 pointer-events-auto\">\n          <div className=\"flex items-center gap-1.5\">\n            <span className=\"text-yellow-400 font-black font-mono text-base tracking-tighter\">A</span>\n            <span className=\"text-zinc-500 font-mono text-sm\">&amp;</span>\n            <span className=\"text-red-500 font-black font-mono text-base tracking-tighter\">A</span>\n            <div className=\"w-[1px] h-3 bg-zinc-800 mx-1.5\" />\n            <h1 className=\"text-xs font-mono font-black tracking-widest text-zinc-300\">\n              AQU\303\215 / ALL\303\201\n            </h1>\n          </div>\n          \n          <div className=\"flex items-center gap-1 bg-zinc-900/60 px-2 py-1 rounded-md border border-zinc-800/80\">\n            <Layers className=\"w-3.5 h-3.5 text-zinc-500\" />\n            <span className=\"text-[10px] font-mono text-zinc-400\">\n              {filteredItems.length} {filteredItems.length === 1 ? \'REGISTRO\' : \'REGISTROS\'}\n            </span>\n          </div>\n        </div>\n\n        {/* Quick Filter Controls */}\n        <div className=\"flex gap-2 justify-center pointer-events-auto\">\n          {/* ALL FILTER */}\n          <button\n            onClick={() => setFilter(\'all\')}\n            className={`px-4 py-1.5 rounded-full font-mono text-[10px] font-bold tracking-wider uppercase border transition-all duration-300 cursor-pointer ${\n              filter === \'all\'\n                ? \'bg-white text-black border-white shadow-[0_0_10px_rgba(255,255,255,0.2)]\'\n                : \'bg-zinc-900/80 border-zinc-800 text-zinc-400 hover:text-white hover:border-zinc-700\'\n            }`}\n          >\n            Ver Todo\n          </button>\n\n          {/* AQU\303\215 FILTER */}\n          <button\n            onClick={() => setFilter(\'aqui\')}\n            className={`px-4 py-1.5 rounded-full font-mono text-[10px] font-bold tracking-wider uppercase border transition-all duration-300 flex items-center gap-1.5 cursor-pointer ${\n              filter === \'aqui\'\n                ? \'bg-yellow-400/20 border-yellow-400 text-yellow-400 shadow-[0_0_12px_rgba(250,204,21,0.25)]\'\n                : \'bg-zinc-900/80 border-zinc-800 text-zinc-400 hover:text-yellow-400 hover:border-yellow-400/40\'\n            }`}\n          >\n            <Sparkles className=\"w-3 h-3\" />\n            Aqu\303\255\n          </button>\n\n          {/* ALL\303\201 FILTER */}\n          <button\n            onClick={() => setFilter(\'alla\')}\n            className={`px-4 py-1.5 rounded-full font-mono text-[10px] font-bold tracking-wider uppercase border transition-all duration-300 flex items-center gap-1.5 cursor-pointer ${\n              filter === \'alla\'\n                ? \'bg-red-500/20 border-red-500 text-red-500 shadow-[0_0_12px_rgba(239,68,68,0.25)]\'\n                : \'bg-zinc-900/80 border-zinc-800 text-zinc-400 hover:text-red-500 hover:border-red-500/40\'\n            }`}\n          >\n            <AlertTriangle className=\"w-3 h-3\" />\n            All\303\241\n          </button>\n        </div>\n      </div>\n\n      {/* Main Snap-Scrolling Feed Area */}\n      <div \n        ref={containerRef}\n        className=\"flex-grow w-full h-full snap-y snap-mandatory overflow-y-scroll scroll-smooth scrollbar-none\"\n        style={{ scrollbarWidth: \'none\', msOverflowStyle: \'none\' }} // Ensure cross-platform scrollbar hiding\n      >\n        {filteredItems.length > 0 ? (\n          filteredItems.map((item) => (\n            <CardContenido key={item.id} item={item} />\n          ))\n        ) : (\n          /* Empty State centered cleanly */\n          <div className=\"w-full h-full flex flex-col items-center justify-center p-8 text-center bg-zinc-950\">\n            <div className=\"absolute inset-0 bg-[linear-gradient(to_right,#1f1f1f_1px,transparent_1px),linear-gradient(to_bottom,#1f1f1f_1px,transparent_1px)] bg-[size:3rem_3rem] opacity-20 pointer-events-none\" />\n            <div className=\"relative z-10 space-y-4 max-w-xs\">\n              <div className=\"w-16 h-16 rounded-full bg-zinc-900 border border-zinc-800 flex items-center justify-center mx-auto text-zinc-600\">\n                <FolderHeart className=\"w-8 h-8\" />\n              </div>\n              <h3 className=\"text-sm font-mono font-bold uppercase tracking-wider text-zinc-300\">\n                BASE DE DATOS VAC\303\215A\n              </h3>\n              <p className=\"text-xs text-zinc-500 leading-relaxed font-normal\">\n                No hay elementos catalogados bajo la secci\303\263n{\' \'}\n                <span className=\"text-zinc-300 font-semibold uppercase font-mono\">\n                  {filter === \'all\' ? \'Ver Todo\' : filter === \'aqui\' ? \'Aqu\303\255\' : \'All\303\241\'}\n                </span>\n                . A\303\261ade un enlace interesante presionando el bot\303\263n flotante de abajo.\n              </p>\n              <button\n                onClick={() => setIsFormOpen(true)}\n                className=\"inline-flex items-center gap-1.5 px-4 py-2 rounded-xl bg-zinc-900 border border-zinc-800 hover:border-zinc-700 text-xs text-yellow-400 font-mono font-bold transition-all cursor-pointer mx-auto\"\n              >\n                <Plus className=\"w-4 h-4\" />\n                <span>Agregar ahora</span>\n              </button>\n            </div>\n          </div>\n        )}\n      </div>\n\n      {/* Persistent Floating Bottom \"+\" Action Button */}\n      <div className=\"absolute bottom-6 right-6 z-30\">\n        <button\n          onClick={() => setIsFormOpen(true)}\n          className=\"w-14 h-14 rounded-full bg-yellow-400 text-black flex items-center justify-center shadow-[0_0_20px_rgba(250,204,21,0.4)] hover:scale-105 active:scale-95 hover:bg-yellow-300 transition-all cursor-pointer\"\n          title=\"A\303\261adir nuevo recurso\"\n        >\n          <Plus className=\"w-7 h-7 stroke-[2.5]\" />\n        </button>\n      </div>\n\n      {/* Floating Scroll Indicator shown on first load if multiple items */}\n      {filteredItems.length > 1 && (\n        <div className=\"absolute bottom-6 left-6 z-30 pointer-events-none\">\n          <div className=\"flex items-center gap-1.5 bg-zinc-900/80 px-2.5 py-1 rounded-full border border-zinc-800 text-[10px] font-mono text-zinc-400 backdrop-blur-sm\">\n            <ArrowUpDown className=\"w-3.5 h-3.5 animate-pulse text-zinc-500\" />\n            <span>SCROLL</span>\n          </div>\n        </div>\n      )}\n\n      {/* Slide-Up Bottom Sheet Entry Form */}\n      <FormularioIngreso isOpen={isFormOpen} onClose={() => setIsFormOpen(false)} />\n    </div>\n  );\n};\n"
    }
