  file_change {
    absolute_path_uri: "file:///src/components/CardContenido.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React from \'react\';\nimport { CurationItem } from \'../types\';\nimport { useApp } from \'../context/AppContext\';\nimport { \n  Youtube, \n  Instagram, \n  Linkedin, \n  Globe, \n  Zap, \n  ExternalLink, \n  Trash2, \n  Calendar,\n  Sparkles,\n  AlertTriangle\n} from \'lucide-react\';\n\ninterface CardContenidoProps {\n  item: CurationItem;\n}\n\nexport const CardContenido: React.FC<CardContenidoProps> = ({ item }) => {\n  const { deleteItem } = useApp();\n\n  // Helper to select icon based on platform\n  const getPlatformIcon = (type: string) => {\n    switch (type) {\n      case \'youtube\':\n        return <Youtube className=\"w-5 h-5 text-red-500\" />;\n      case \'instagram\':\n        return <Instagram className=\"w-5 h-5 text-pink-500\" />;\n      case \'linkedin\':\n        return <Linkedin className=\"w-5 h-5 text-blue-500\" />;\n      case \'tiktok\':\n        return <Zap className=\"w-5 h-5 text-teal-400\" />;\n      default:\n        return <Globe className=\"w-5 h-5 text-zinc-400\" />;\n    }\n  };\n\n  // Helper to get stylized platform label\n  const getPlatformLabel = (type: string) => {\n    switch (type) {\n      case \'youtube\': return \'YouTube\';\n      case \'instagram\': return \'Instagram\';\n      case \'linkedin\': return \'LinkedIn\';\n      case \'tiktok\': return \'TikTok / Short\';\n      default: return \'Web / Art\303\255culo\';\n    }\n  };\n\n  const isAqui = item.category === \'aqui\';\n\n  // Format creation date\n  const formatDate = (dateStr: string) => {\n    try {\n      const date = new Date(dateStr);\n      return date.toLocaleDateString(\'es-ES\', { \n        month: \'short\', \n        day: \'numeric\',\n        hour: \'2-digit\',\n        minute: \'2-digit\'\n      });\n    } catch {\n      return \'Reciente\';\n    }\n  };\n\n  return (\n    <div \n      id={`card-${item.id}`}\n      className=\"snap-start w-full h-full flex-shrink-0 flex flex-col justify-between p-6 relative bg-zinc-950 overflow-hidden\"\n    >\n      {/* Cybersecurity Futuristic Grid Background */}\n      <div className=\"absolute inset-0 bg-[linear-gradient(to_right,#1f1f1f_1px,transparent_1px),linear-gradient(to_bottom,#1f1f1f_1px,transparent_1px)] bg-[size:3rem_3rem] opacity-20\" />\n      \n      {/* Decorative Radial Vignette Overlay */}\n      <div className=\"absolute inset-0 bg-gradient-to-t from-zinc-950 via-transparent to-zinc-950/80 pointer-events-none\" />\n\n      {/* Dynamic Glowing Aura behind the card */}\n      <div \n        className={`absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-72 h-72 rounded-full blur-[120px] opacity-10 pointer-events-none transition-colors duration-500 ${\n          isAqui ? \'bg-yellow-400\' : \'bg-red-500\'\n        }`} \n      />\n\n      {/* Top Banner indicating Category (Aqu\303\255 vs All\303\241) */}\n      <div className=\"relative z-10 flex justify-between items-center mt-12 md:mt-14\">\n        <div className=\"flex items-center gap-2\">\n          <span className={`relative flex h-3 w-3`}>\n            <span className={`animate-ping absolute inline-flex h-full w-full rounded-full opacity-75 ${\n              isAqui ? \'bg-yellow-400\' : \'bg-red-500\'\n            }`}></span>\n            <span className={`relative inline-flex rounded-full h-3 w-3 ${\n              isAqui ? \'bg-yellow-400\' : \'bg-red-500\'\n            }`}></span>\n          </span>\n          <span className={`text-xs font-mono tracking-widest font-bold uppercase ${\n            isAqui ? \'text-yellow-400\' : \'text-red-500\'\n          }`}>\n            {isAqui ? \'AQU\303\215 // INSPIRACI\303\223N\' : \'ALL\303\201 // EVITAR\'}\n          </span>\n        </div>\n\n        <button\n          onClick={() => deleteItem(item.id)}\n          className=\"p-2 rounded-lg bg-zinc-900/60 border border-zinc-800 text-zinc-400 hover:text-red-500 hover:border-red-500/50 transition-all duration-300 backdrop-blur-sm cursor-pointer\"\n          title=\"Eliminar de la colecci\303\263n\"\n        >\n          <Trash2 className=\"w-4 h-4\" />\n        </button>\n      </div>\n\n      {/* Central Glassmorphic Card Container */}\n      <div \n        className={`relative z-10 my-auto w-full transition-all duration-500 rounded-2xl border backdrop-blur-md p-6 flex flex-col justify-between ${\n          isAqui \n            ? \'bg-zinc-900/40 border-yellow-400/30 shadow-[0_0_25px_rgba(250,204,21,0.06)] hover:border-yellow-400/50\' \n            : \'bg-zinc-900/40 border-red-500/30 shadow-[0_0_25px_rgba(239,68,68,0.06)] hover:border-red-500/50\'\n        }`}\n      >\n        {/* Card Header: Platform Indicator */}\n        <div className=\"flex items-center justify-between mb-4 pb-3 border-b border-zinc-800/50\">\n          <div className=\"flex items-center gap-2 bg-zinc-950/60 px-3 py-1.5 rounded-full border border-zinc-800/60\">\n            {getPlatformIcon(item.contentType)}\n            <span className=\"text-xs font-mono font-medium text-zinc-300\">\n              {getPlatformLabel(item.contentType)}\n            </span>\n          </div>\n          \n          <div className=\"flex items-center gap-1.5 text-xs text-zinc-500 font-mono\">\n            <Calendar className=\"w-3.5 h-3.5 text-zinc-600\" />\n            <span>{formatDate(item.createdAt)}</span>\n          </div>\n        </div>\n\n        {/* Card Content: Title & Description */}\n        <div className=\"flex-grow flex flex-col justify-center min-h-[140px] py-2\">\n          <div className=\"flex items-start gap-2.5 mb-3\">\n            {isAqui ? (\n              <Sparkles className=\"w-5 h-5 text-yellow-400 flex-shrink-0 mt-1\" />\n            ) : (\n              <AlertTriangle className=\"w-5 h-5 text-red-500 flex-shrink-0 mt-1\" />\n            )}\n            <h3 className=\"text-xl md:text-2xl font-bold text-white tracking-tight leading-tight line-clamp-3\">\n              {item.title}\n            </h3>\n          </div>\n\n          <p className=\"text-sm text-zinc-400 leading-relaxed line-clamp-4 font-normal mt-1\">\n            {item.description || \'Sin descripci\303\263n adicional para este elemento catalogado.\'}\n          </p>\n        </div>\n\n        {/* Action Button: Open Original Link */}\n        <div className=\"mt-5 pt-3 border-t border-zinc-800/50\">\n          <a\n            href={item.url}\n            target=\"_blank\"\n            rel=\"noopener noreferrer referrerPolicy=no-referrer\"\n            className={`w-full py-3 px-4 rounded-xl font-mono text-xs font-bold uppercase tracking-wider flex items-center justify-center gap-2 transition-all duration-300 border backdrop-blur-sm cursor-pointer ${\n              isAqui\n                ? \'bg-yellow-400/10 border-yellow-400/40 text-yellow-400 hover:bg-yellow-400 hover:text-black hover:shadow-[0_0_15px_rgba(250,204,21,0.3)]\'\n                : \'bg-red-500/10 border-red-500/40 text-red-400 hover:bg-red-500 hover:text-white hover:shadow-[0_0_15px_rgba(239,68,68,0.3)]\'\n            }`}\n          >\n            <span>Ver contenido original</span>\n            <ExternalLink className=\"w-4 h-4\" />\n          </a>\n        </div>\n      </div>\n\n      {/* Scroll Down / Indicator Footnote */}\n      <div className=\"relative z-10 w-full text-center pb-8 md:pb-12 text-zinc-600 text-[10px] font-mono tracking-widest uppercase\">\n        <span className=\"inline-block animate-bounce\">\342\206\223 Desliza para explorar \342\206\223</span>\n      </div>\n    </div>\n  );\n};\n"
    }
