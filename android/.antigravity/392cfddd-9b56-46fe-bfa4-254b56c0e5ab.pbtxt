    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport React from \'react\';\nimport { AppProvider, useApp } from \'./context/AppContext\';\nimport { FeedReels } from \'./components/FeedReels\';\nimport { \n  Smartphone, \n  Monitor, \n  Sparkles, \n  AlertTriangle, \n  Layers, \n  Database,\n  Info,\n  ExternalLink\n} from \'lucide-react\';\n\nfunction AppContent() {\n  const { layoutMode, setLayoutMode, items, filter, setFilter } = useApp();\n\n  // Calculate real metrics from existing catalog items\n  const totalCount = items.length;\n  const aquiCount = items.filter((item) => item.category === \'aqui\').length;\n  const allaCount = items.filter((item) => item.category === \'alla\').length;\n\n  const handleToggleLayout = () => {\n    setLayoutMode(layoutMode === \'mobile\' ? \'desktop\' : \'mobile\');\n  };\n\n  return (\n    <div className=\"min-h-screen w-full bg-zinc-950 text-white flex flex-col items-center justify-center relative font-sans overflow-x-hidden\">\n      \n      {/* Abstract Cybersecurity Background Grid */}\n      <div className=\"absolute inset-0 bg-[linear-gradient(to_right,#141414_1px,transparent_1px),linear-gradient(to_bottom,#141414_1px,transparent_1px)] bg-[size:4rem_4rem] pointer-events-none\" />\n      <div className=\"absolute top-0 left-0 right-0 h-96 bg-gradient-to-b from-yellow-500/5 via-transparent to-transparent pointer-events-none\" />\n\n      {/* Persistent Floating Layout Control Panel */}\n      <div className=\"fixed top-4 right-4 z-50 flex items-center gap-1 bg-zinc-900/90 border border-zinc-800 p-1.5 rounded-full shadow-[0_4px_20px_rgba(0,0,0,0.5)] backdrop-blur-md\">\n        <button\n          onClick={() => setLayoutMode(\'mobile\')}\n          className={`flex items-center gap-1.5 px-3 py-1.5 rounded-full font-mono text-[10px] font-bold tracking-wider uppercase transition-all duration-300 cursor-pointer ${\n            layoutMode === \'mobile\'\n              ? \'bg-yellow-400 text-black shadow-[0_0_10px_rgba(250,204,21,0.25)]\'\n              : \'text-zinc-400 hover:text-white\'\n          }`}\n          title=\"Vista M\303\263vil (Aspecto 9:16)\"\n        >\n          <Smartphone className=\"w-3.5 h-3.5\" />\n          <span className=\"hidden sm:inline\">M\303\263vil 9:16</span>\n        </button>\n\n        <button\n          onClick={() => setLayoutMode(\'desktop\')}\n          className={`flex items-center gap-1.5 px-3 py-1.5 rounded-full font-mono text-[10px] font-bold tracking-wider uppercase transition-all duration-300 cursor-pointer ${\n            layoutMode === \'desktop\'\n              ? \'bg-yellow-400 text-black shadow-[0_0_10px_rgba(250,204,21,0.25)]\'\n              : \'text-zinc-400 hover:text-white\'\n          }`}\n          title=\"Vista Escritorio (Pantalla Completa)\"\n        >\n          <Monitor className=\"w-3.5 h-3.5\" />\n          <span className=\"hidden sm:inline\">Escritorio</span>\n        </button>\n      </div>\n\n      {layoutMode === \'mobile\' ? (\n        /* --- 1. MOBILE ASPECT RATIO SIMULATOR VIEW (9:16) --- */\n        <div className=\"flex flex-col items-center justify-center p-4 py-8 z-10 w-full max-w-md h-screen\">\n          \n          {/* Aesthetic smartphone wrapper */}\n          <div className=\"relative w-full max-w-[390px] h-full max-h-[820px] aspect-[9/16] rounded-[44px] border-[10px] border-zinc-900 bg-zinc-950 shadow-[0_0_50px_rgba(0,0,0,0.85),0_0_30px_rgba(250,204,21,0.03)] overflow-hidden transition-all duration-500 flex flex-col\">\n            \n            {/* Front-facing camera notch & speaker grill */}\n            <div className=\"absolute top-0 left-1/2 -translate-x-1/2 w-40 h-7 bg-zinc-900 rounded-b-2xl z-40 flex items-center justify-center gap-3\">\n              <div className=\"w-12 h-1 bg-zinc-800 rounded-full\" />\n              <div className=\"w-2.5 h-2.5 bg-zinc-950 rounded-full border border-zinc-800\" />\n            </div>\n\n            {/* Simulated status bar */}\n            <div className=\"absolute top-7 left-0 right-0 h-6 px-6 flex justify-between items-center text-[10px] font-mono text-zinc-500 z-30 pointer-events-none\">\n              <span>9:41 AM</span>\n              <div className=\"flex items-center gap-1.5\">\n                <span>5G</span>\n                <span>100%</span>\n              </div>\n            </div>\n\n            {/* Inner Content Area */}\n            <div className=\"flex-grow w-full h-full relative overflow-hidden\">\n              <FeedReels />\n            </div>\n\n            {/* Bottom Virtual Home Indicator bar */}\n            <div className=\"absolute bottom-1.5 left-1/2 -translate-x-1/2 w-32 h-1 bg-zinc-800/80 rounded-full z-40\" />\n          </div>\n\n          {/* Quick Helper under the phone mock */}\n          <p className=\"mt-4 text-center text-zinc-600 text-[10px] font-mono tracking-wider max-w-xs\">\n            SIMULADOR M\303\223VIL // CAMBIE EL MODO DE LAYOUT PARA EXPERIENCIA EXPANDIDA\n          </p>\n        </div>\n      ) : (\n        /* --- 2. FULL DESKTOP DASHBOARD VIEW --- */\n        <div className=\"w-full h-screen z-10 flex overflow-hidden\">\n          \n          {/* Desktop Left Sidebar: Interactive Control & Stats Console */}\n          <aside className=\"w-80 h-full border-r border-zinc-900 bg-zinc-950/80 backdrop-blur-md p-6 flex flex-col justify-between overflow-y-auto shrink-0 select-none\">\n            \n            {/* Header Identity */}\n            <div className=\"space-y-6\">\n              <div>\n                <div className=\"flex items-center gap-2 mb-2\">\n                  <span className=\"px-1.5 py-0.5 rounded bg-yellow-400 text-black font-black font-mono text-xs tracking-tighter\">AQ</span>\n                  <span className=\"text-zinc-500 font-mono text-xs\">&amp;</span>\n                  <span className=\"px-1.5 py-0.5 rounded bg-red-500 text-white font-black font-mono text-xs tracking-tighter\">AL</span>\n                  <span className=\"text-xs font-mono font-bold uppercase tracking-widest text-zinc-500 ml-1\">\n                    CONSOLE\n                  </span>\n                </div>\n                <h2 className=\"text-lg font-bold tracking-tight text-white uppercase font-mono\">\n                  Aqu\303\255 y All\303\241\n                </h2>\n                <p className=\"text-xs text-zinc-500 font-normal leading-relaxed mt-1\">\n                  Tu curador interactivo de buenas pr\303\241cticas e inspiraciones frente a antipatrones de internet.\n                </p>\n              </div>\n\n              {/* Real DB Metrics Section */}\n              <div className=\"space-y-2.5\">\n                <span className=\"text-[10px] font-mono font-bold tracking-wider text-zinc-400 uppercase flex items-center gap-1.5\">\n                  <Database className=\"w-3.5 h-3.5 text-zinc-500\" />\n                  M\303\251tricas Locales\n                </span>\n\n                {/* Total Stats Card */}\n                <div className=\"bg-zinc-900/40 border border-zinc-900 p-4 rounded-xl flex items-center justify-between\">\n                  <div className=\"flex items-center gap-2.5\">\n                    <Layers className=\"w-5 h-5 text-zinc-400\" />\n                    <div>\n                      <h4 className=\"text-xs font-bold text-zinc-300 uppercase font-mono\">Total Guardado</h4>\n                      <p className=\"text-[10px] text-zinc-500 font-normal\">Persistencia en cach\303\251</p>\n                    </div>\n                  </div>\n                  <span className=\"text-2xl font-black font-mono text-white\">{totalCount}</span>\n                </div>\n\n                {/* Aqu\303\255 Stats Card */}\n                <button\n                  onClick={() => setFilter(\'aqui\')}\n                  className={`w-full bg-zinc-900/40 border p-4 rounded-xl flex items-center justify-between transition-all text-left cursor-pointer ${\n                    filter === \'aqui\' \n                      ? \'border-yellow-400/50 bg-yellow-400/[0.02]\' \n                      : \'border-zinc-900 hover:border-zinc-800\'\n                  }`}\n                >\n                  <div className=\"flex items-center gap-2.5\">\n                    <Sparkles className=\"w-5 h-5 text-yellow-400\" />\n                    <div>\n                      <h4 className=\"text-xs font-bold text-zinc-300 uppercase font-mono\">Aqu\303\255 (Buenas)</h4>\n                      <p className=\"text-[10px] text-zinc-500 font-normal\">Patrones que inspiran</p>\n                    </div>\n                  </div>\n                  <span className=\"text-2xl font-black font-mono text-yellow-400\">{aquiCount}</span>\n                </button>\n\n                {/* All\303\241 Stats Card */}\n                <button\n                  onClick={() => setFilter(\'alla\')}\n                  className={`w-full bg-zinc-900/40 border p-4 rounded-xl flex items-center justify-between transition-all text-left cursor-pointer ${\n                    filter === \'alla\' \n                      ? \'border-red-500/50 bg-red-500/[0.02]\' \n                      : \'border-zinc-900 hover:border-zinc-800\'\n                  }`}\n                >\n                  <div className=\"flex items-center gap-2.5\">\n                    <AlertTriangle className=\"w-5 h-5 text-red-500\" />\n                    <div>\n                      <h4 className=\"text-xs font-bold text-zinc-300 uppercase font-mono\">All\303\241 (Malas)</h4>\n                      <p className=\"text-[10px] text-zinc-500 font-normal\">Lecciones a evitar</p>\n                    </div>\n                  </div>\n                  <span className=\"text-2xl font-black font-mono text-red-500\">{allaCount}</span>\n                </button>\n              </div>\n\n              {/* Information Guild Cards */}\n              <div className=\"bg-zinc-900/30 border border-zinc-900 p-4 rounded-xl space-y-2.5\">\n                <div className=\"flex items-center gap-1.5 text-xs font-mono font-bold text-zinc-400\">\n                  <Info className=\"w-4 h-4 text-zinc-500\" />\n                  <span>GU\303\215A DE USO</span>\n                </div>\n                <div className=\"space-y-2 text-xs text-zinc-500 font-normal leading-relaxed\">\n                  <p>\n                    \342\200\242 <strong className=\"text-yellow-400\">Aqu\303\255:</strong> A\303\261ade recursos t\303\251cnicos, art\303\255culos inspiradores, carruseles de UI refinada o tips que fomenten buenas pr\303\241cticas.\n                  </p>\n                  <p>\n                    \342\200\242 <strong className=\"text-red-500\">All\303\241:</strong> Catalogar errores fatales de c\303\263digo, malas pr\303\241cticas de dise\303\261o, o bugs cr\303\255ticos de producci\303\263n para no repetirlos.\n                  </p>\n                </div>\n              </div>\n            </div>\n\n            {/* Footer Metadata */}\n            <div className=\"border-t border-zinc-900 pt-4 space-y-2 text-[10px] font-mono text-zinc-600\">\n              <div className=\"flex items-center justify-between\">\n                <span>ESTADO: ONLINE</span>\n                <span className=\"w-2 h-2 rounded-full bg-emerald-500 animate-pulse\" />\n              </div>\n              <p>CRAFTED IN SPAIN // CODESYNC</p>\n            </div>\n          </aside>\n\n          {/* Desktop Central Feed Container */}\n          <main className=\"flex-grow h-full flex items-center justify-center relative bg-zinc-950\">\n            {/* Glowing borders and bounds similar to a tablet feed */}\n            <div className=\"w-full max-w-lg h-full border-x border-zinc-900 relative\">\n              <FeedReels />\n            </div>\n          </main>\n        </div>\n      )}\n    </div>\n  );\n}\n\nexport default function App() {\n  return (\n    <AppProvider>\n      <AppContent />\n    </AppProvider>\n  );\n}\n"
    }
